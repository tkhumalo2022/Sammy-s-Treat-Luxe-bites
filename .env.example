# PostgreSQL connection string from Supabase or another Postgres provider
DATABASE_URL=

# Generate a long random value; never commit the real secret
PAYLOAD_SECRET=

# Enables AI-generated chatbot responses. Keep server-side only.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional order email delivery via Resend. Without these, requests fall back to WhatsApp.
RESEND_API_KEY=
ORDER_NOTIFICATION_EMAIL=
ORDER_FROM_EMAIL="Luxe Bites Orders <orders@your-verified-domain.example>"
